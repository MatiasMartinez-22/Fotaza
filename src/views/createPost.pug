doctype html
html
    head
        title Crear Publicación

    body
        h1 Nueva Publicación

        form(action="/crear-publicacion" method="POST")
            div
                label(for="titulo") Título
                br
                input(
                    type="text"
                    name="titulo"
                    id="titulo"
                    required
                )

            br

            div
                label(for="descripcion") Descripción
                br
                textarea(
                    name="descripcion"
                    id="descripcion"
                    rows="5"
                    cols="40"
                    required
                )

            br

            button(type="submit")
                | Publicar

        br

        a(href="/")
            | Volver al inicio