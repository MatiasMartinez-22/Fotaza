extends layout

block content

    h1 Bienvenido a Fotaza

    if user

        div(class="actions-home")
            p Hola #{user.nombre}

            form(action="/buscar" method="GET")
                input(
                    type="text"
                    name="q"
                    placeholder="Buscar publicaciones..."
                )
                button(type="submit") Buscar

            form(action="/logout" method="POST")
                button(type="submit") Cerrar sesión

        hr

        each publicacion in publicaciones

            div(style="border:1px solid #ccc; padding:15px; margin-bottom:20px;")

                h2= publicacion.titulo

                p= publicacion.descripcion

                p
                    b Autor:
                    |  
                    a(href=`/perfil/${publicacion.id_usuario}`) #{publicacion.nombre} #{publicacion.apellido}

                if publicacion.id_usuario != user.id_usuario

                    if publicacion.loSigue

                        form(action=`/dejar-seguir/${publicacion.id_usuario}` method="POST")
                            button(type="submit") Dejar de seguir

                    else

                        form(action=`/seguir/${publicacion.id_usuario}` method="POST")
                            button(type="submit") Seguir

                if publicacion.imagen_base64

                    img(
                        src=publicacion.imagen_base64
                        style="max-width:500px; max-height:500px;"
                    )

                    br
                    br

                    p
                        b Valoración:
                        |  ⭐ #{publicacion.promedio_valoracion} / 5 (#{publicacion.cantidad_valoraciones} votos)

                    form(action=`/valorar/${publicacion.id_imagen}` method="POST")
                        select(name="valor" required)
                            option(value="1") ⭐ 1
                            option(value="2") ⭐⭐ 2
                            option(value="3") ⭐⭐⭐ 3
                            option(value="4") ⭐⭐⭐⭐ 4
                            option(value="5") ⭐⭐⭐⭐⭐ 5

                        button(type="submit") Valorar

                    hr

                    h4 Comentarios

                    if publicacion.comentarios.length == 0
                        p No hay comentarios.

                    else
                        each comentario in publicacion.comentarios
                            p
                                b #{comentario.nombre} #{comentario.apellido}:
                                |  #{comentario.texto}

                    br

                    form(action="/comentarios" method="POST")
                        input(
                            type="hidden"
                            name="id_imagen"
                            value=publicacion.id_imagen
                        )

                        input(
                            type="text"
                            name="texto"
                            placeholder="Escribí un comentario..."
                            required
                        )

                        button(type="submit") Comentar

    else

        a(href="/login") Iniciar sesión

        br

        a(href="/signup") Registrarse